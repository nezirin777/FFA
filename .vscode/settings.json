{
    // 文字コードの自動判別を有効化
    "files.autoGuessEncoding": true,
    // 判別する際の優先候補を制限（誤判定を減らします）
    "files.candidateGuessEncodings": ["utf8", "shiftjis"],

    // HTMLファイルは常にShift_JIS（shiftjis）で読み書きする設定
    "[html]": {
        "files.encoding": "shiftjis"
    },
    "[pl]": {
        "files.encoding": "shiftjis"
    }
}
